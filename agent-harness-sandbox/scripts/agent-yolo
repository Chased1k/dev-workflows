#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
agent="${1:-}"
if [[ -z "$agent" ]]; then
  cat >&2 <<'USAGE'
Usage: scripts/agent-yolo <claude|codex|agy|opencode|shell> [-extra PATH ...] [agent args...]

Runs an AI coding harness in a disposable Docker/Colima container with only the
current directory mounted at /workspace. The Docker image is built on first use.
USAGE
  exit 2
fi
shift || true

image="${AGENT_SANDBOX_IMAGE:-agent-harness-sandbox:statusline-v2}"
workspace="$(pwd)"
policy="$repo_root/agent/sandbox/policy/agent-guardrails.json"
shims="$repo_root/agent/sandbox/shims"
dockerfile="$repo_root/agent/sandbox/Dockerfile"
home_volume="${AGENT_HOME_VOLUME:-agent-harness-home}"
extra_mounts=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -extra|--extra)
      if [[ -z "${2:-}" ]]; then
        printf '%s\n' "agent-sandbox: $1 requires a path" >&2
        exit 2
      fi
      extra_path="$(cd "$2" && pwd)"
      extra_name="$(basename "$extra_path")"
      extra_mounts+=(-v "$extra_path:/extra/$extra_name")
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if ! command -v docker >/dev/null 2>&1; then
  printf '%s\n' "agent-sandbox: docker is required. Install Docker/Colima and try again." >&2
  exit 127
fi

if ! docker info >/dev/null 2>&1; then
  if command -v colima >/dev/null 2>&1; then
    printf '%s\n' "agent-sandbox: Docker is not running; starting Colima..." >&2
    colima start
  else
    printf '%s\n' "agent-sandbox: Docker is not running, and colima was not found." >&2
    printf '%s\n' "Start Docker Desktop or install/start Colima, then try again." >&2
    exit 1
  fi
fi

if ! docker info >/dev/null 2>&1; then
  printf '%s\n' "agent-sandbox: Docker is still unavailable after startup attempt." >&2
  exit 1
fi

if ! docker image inspect "$image" >/dev/null 2>&1; then
  printf '%s\n' "agent-sandbox: building missing Docker image: $image" >&2
  docker build -t "$image" -f "$dockerfile" "$repo_root"
fi

container_path="/opt/agent-shims:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
docker_tty_args=(-i)
if [[ -t 0 && -t 1 ]]; then
  docker_tty_args=(-it)
fi

common=(
  docker run --rm "${docker_tty_args[@]}"
  --user node
  --cap-drop=ALL
  --security-opt no-new-privileges
  -e PATH="$container_path"
  -e HOME=/home/node
  -e AGENT_GUARDRAILS_FILE=/etc/agent-guardrails.json
  -e ANTHROPIC_API_KEY
  -e OPENAI_API_KEY
  -e GEMINI_API_KEY
  -v "$home_volume:/home/node"
  -v "$workspace:/workspace"
  "${extra_mounts[@]}"
  -v "$policy:/etc/agent-guardrails.json:ro"
  -v "$shims:/opt/agent-shims:ro"
  -w /workspace
  "$image"
)

case "$agent" in
  claude)
    exec "${common[@]}" sh -c '/usr/local/share/agent-harness/bin/bootstrap-agent-home && exec claude --dangerously-skip-permissions "$@"' sh "$@"
    ;;
  codex)
    exec "${common[@]}" sh -c '/usr/local/share/agent-harness/bin/bootstrap-agent-home && exec codex --dangerously-bypass-approvals-and-sandbox "$@"' sh "$@"
    ;;
  agy)
    exec "${common[@]}" sh -c '/usr/local/share/agent-harness/bin/bootstrap-agent-home && command -v agy >/dev/null 2>&1 || {
      printf "%s\n" "agent-sandbox: agy is not installed in this Docker image." >&2
      printf "%s\n" "Build a custom Linux image that provides agy, then set AGENT_SANDBOX_IMAGE." >&2
      exit 127
    }
    exec agy --dangerously-skip-permissions "$@"' sh "$@"
    ;;
  opencode)
    # Installed opencode 1.17.10 does not advertise a dangerous skip flag in --help.
    # Keep it in the same external sandbox and pass any explicit flags through.
    exec "${common[@]}" sh -c '/usr/local/share/agent-harness/bin/bootstrap-agent-home && exec opencode "$@"' sh "$@"
    ;;
  shell)
    exec "${common[@]}" sh -c '/usr/local/share/agent-harness/bin/bootstrap-agent-home && exec bash "$@"' sh "$@"
    ;;
  *)
    printf '%s\n' "Unknown agent: $agent" >&2
    exit 2
    ;;
esac
